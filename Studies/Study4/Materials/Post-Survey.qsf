isplay":"3"},"4":{"Display":"4"},"5":{"Display":"Extremely Confident (5)"}},"ChoiceOrder":["1","2","3","4","5"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":6,"NextAnswerId":1,"QuestionID":"QID85"}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"SQ","PrimaryAttribute":"QID86","SecondaryAttribute":"First, please tell us the extent to which you agree or disagree with each of the following statem...","TertiaryAttribute":null,"Payload":{"AnswerOrder":["8","9","10","11","12"],"Answers":{"10":{"Display":"Neither agree nor disagree"},"11":{"Display":"Somewhat agree"},"12":{"Display":"Strongly agree"},"8":{"Display":"Strongly disagree"},"9":{"Display":"Somewhat disagree"}},"ChoiceDataExportTags":{"1":"CouldLearn_1","3":"CouldLearn_2","6":"CouldLearn_3"},"ChoiceOrder":["1","3","6"],"Choices":{"1":{"Display":"I managed to learn which characteristics of companies (if any) had an impact on the ROI they generated"},"3":{"Display":"I understood how the characteristics of companies relate to their ROIs"},"6":{"Display":"I know which characteristics of companies affected their ROIs, and in which direction"}},"Configuration":{"Autoscale":{"XScale":{"Name":"agreeDisagree","Reverse":false,"Type":"likert"}},"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"none","TextPosition":"inline","WhiteSpace":"OFF"},"DataExportTag":"CouldLearn","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":13,"NextChoiceId":8,"QuestionDescription":"First, please tell us the extent to which you agree or disagree with each of the following statem...","QuestionID":"QID86","QuestionText":"First, please tell us the extent to which you agree or disagree with each of the following statements.&nbsp;","QuestionText_Unsafe":"First, please tell us the extent to which you agree or disagree with each of the following statements.&nbsp;","Que