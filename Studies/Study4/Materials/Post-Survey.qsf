{"SurveyEntry":{"SurveyID":"SV_1HW7EaM6F6XPgIm","SurveyName":"2025-10-28 - Investing Strategy Prompt - Post","SurveyDescription":null,"SurveyOwnerID":"UR_8HNsUBv4Xq1C36B","SurveyBrandID":"cuboulder","DivisionID":null,"SurveyLanguage":"EN","SurveyActiveResponseSet":"RS_9XBBxcb3D2viVGC","SurveyStatus":"Active","SurveyStartDate":"0000-00-00 00:00:00","SurveyExpirationDate":"0000-00-00 00:00:00","SurveyCreationDate":"2025-10-28 11:49:47","CreatorID":"UR_8HNsUBv4Xq1C36B","LastModified":"2026-04-21 10:46:21","LastAccessed":"0000-00-00 00:00:00","LastActivated":"2025-10-28 12:00:36","Deleted":null},"SurveyElements":[{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"BL","PrimaryAttribute":"Survey Blocks","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"1":{"Type":"Trash","Description":"Trash \/ Unused Questions","ID":"BL_1LmOTgbHDv8TdTn","BlockElements":[{"Type":"Question","QuestionID":"QID80"},{"Type":"Question","QuestionID":"QID75"},{"Type":"Question","QuestionID":"QID86"},{"Type":"Question","QuestionID":"QID83"},{"Type":"Question","QuestionID":"QID85"}]},"11":{"Type":"Standard","SubType":"","Description":"AttrBlock","ID":"BL_5BJS588gYYkeUUl","BlockElements":[{"Type":"Question","QuestionID":"QID31"},{"Type":"Question","QuestionID":"QID47"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID87"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID81"},{"Type":"Question","QuestionID":"QID84"},{"Type":"Page Break"},{"Type":"Question","QuestionID":"QID82"}]}}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"FL","PrimaryAttribute":"Survey Flow","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"Type":"Root","FlowID":"FL_1","Flow":[{"Type":"EmbeddedData","FlowID":"FL_5","EmbeddedData":[{"Description":"turkid","Type":"Recipient","Field":"turkid","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"condid","Type":"Recipient","Field":"condid","VariableType":"String","DataVisibility":[],"AnalyzeText":false},{"Description":"message_type","Type":"Recipient","Field":"message_type","VariableType":"String","DataVisibility":[],"AnalyzeText":false}]},{"Type":"Standard","ID":"BL_5BJS588gYYkeUUl","FlowID":"FL_18","Autofill":[]}],"Properties":{"Count":23}}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"b5653928-3f38-4418-b524-ff0405a31d68"}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"87","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"RS","PrimaryAttribute":"RS_9XBBxcb3D2viVGC","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"Redirect","Header":"<script>\n\/\/ Helper functions for formatting numbers\nfunction asDollarAmount(x) {\n    return \"$\" + x.toLocaleString(\"en-US\", { minimumFractionDigits: 0, maximumFractionDigits: 0 });\n}\n\nfunction asAmount(x) {\n    return x.toLocaleString(\"en-US\", { minimumFractionDigits: 0, maximumFractionDigits: 0 });\n}\n\n\/\/ Main function to generate signal range\nfunction generateSignalRange(x, tokens, attribute) {\n    let exclusionLevel = tokens * 10;\n\n    \/\/ Ensure exclusionLevel is between 0 and 100\n    if (exclusionLevel < 0 || exclusionLevel > 100) {\n        throw new Error(\"Exclusion level must be between 0 and 100.\");\n    }\n    \n    if (exclusionLevel == 0) {\n        return \"?\";\n    }\n\n    let A, B;\n\n    if (attribute === \"valuation\") {\n        A = 500000;\n        B = 3000000;\n        x = parseFloat(x);\n    } else if (attribute === \"competitors\") {\n        A = 2;\n        B = 14;\n        x = parseFloat(x);\n    } else if (attribute === \"customers\") {\n        A = 2000;\n        B = 14000;\n        x = parseFloat(x);\n    } else {\n\t\tconst possibleValues = [\"Robotics\", \"Electronics\", \"Biotechnology\"];\n\n        \/\/ Compute probabilities for exclusion based on tokens\n        let excludeOneProbability = Math.min(1, tokens \/ 5); \/\/ Higher tokens, higher chance of excluding one\n        let excludeTwoProbability = Math.min(1, Math.max(0, (tokens - 5) \/ 5)); \/\/ Higher tokens after 4, higher chance of excluding two\n\n        \/\/ Determine how many options to exclude\n        let randomValue = Math.random(); \/\/ Generate a random number between 0 and 1\n        if (randomValue < excludeTwoProbability) {\n            \/\/ Exclude two options\n            return x;\n        } else if (randomValue < excludeTwoProbability + excludeOneProbability) {\n            \/\/ Exclude one option\n            const sampledValue = possibleValues.filter(value => value !== x)[Math.floor(Math.random() * 2)];\n            return x + \" or \" + sampledValue;\n        } else {\n            \/\/ Exclude zero options\n            return \"Robotics, Electronics, or Biotechnology\";\n        }\n    }\n\n    \/\/ Calculate the inclusion fraction and inclusion width\n    const inclusionFraction = (100 - exclusionLevel) \/ 100;\n    const totalRange = B - A;\n    const inclusionWidth = totalRange * inclusionFraction;\n\n    \/\/ Define the bounds of the inclusion range\n    let lowerBound = Math.max(A, x - inclusionWidth \/ 2);\n    let upperBound = Math.min(B, x + inclusionWidth \/ 2);\n\n    \/\/ Adjust bounds to ensure the range aligns with inclusion width\n    if ((upperBound - lowerBound) < inclusionWidth) {\n        if (lowerBound === A) {\n            upperBound = A + inclusionWidth;\n        } else if (upperBound === B) {\n            lowerBound = B - inclusionWidth;\n        }\n    }\n\n    \/\/ Format and return the range\n    if (lowerBound !== upperBound) {\n        const values = [Math.round(lowerBound), Math.round(upperBound)];\n        if (attribute === \"valuation\") {\n            return values.map(asDollarAmount).join(\"-\");\n        } else {\n            return values.map(asAmount).join(\"-\");\n        }\n    } else {\n        const value = Math.round(lowerBound);\n        if (attribute === \"valuation\") {\n            return asDollarAmount(value);\n        } else {\n            return asAmount(value);\n        }\n    }\n}\n<\/script>","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SkinLibrary":"cuboulder","SkinType":"templated","Skin":{"brandingId":"2877638256","templateId":"*base","overrides":null},"NewScoring":1,"EOSMessage":"MS_bKJxVD4kv84uT9b","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"Online Survey Software | Qualtrics Survey Solutions","SurveyMetaDescription":"Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.","PasswordProtection":"No","AnonymizeResponse":"No","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","ResponseSummary":"No","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSRedirectURL":"https:\/\/connect.cloudresearch.com\/participant\/project\/3BD4FDF962\/complete","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":"","SurveyLinkCompletedMessageLibrary":"","headerMid":"","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","PartialDeletion":null,"SurveyName":"2025-10-28 - Investing Strategy Prompt - Post","ProtectSelectionIds":true,"CustomStyles":{"customCSS":".project-label {\n  padding: 0 6px 0 6px;\n  color: black;\n}\n\n.project-one {\n  background-color: #ff470f;\n}\n\n.project-two {\n  background-color: #ffdd57;\n}\n\n.project-three {\n  background-color: #23d160;\n}\n\n.project-four {\n  background-color: #00d1b2;\n}"}}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"Thank you for playing the game. We now have a few questions to ask you.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>Thank you for playing the game.<\/div><div><br><\/div><div>We now have a few questions to ask you.<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for playing the game. We now have a few questions to ask you.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID31","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_1HW7EaM6F6XPgIm","Element":"SQ","PrimaryAttribute":"QID47","Sec