nse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":7,"NextAnswerId":13,"Answers":{"8":{"Display":"Strongly disagree"},"9":{"Display":"Somewhat disagree"},"10":{"Display":"Neither agree nor disagree"},"11":{"Display":"Somewhat agree"},"12":{"Display":"Strongly agree"}},"AnswerOrder":["8","9","10","11","12"],"ChoiceDataExportTags":{"1":"DV_1","3":"DV_2","4":"DV_3","6":"DV_4_R"},"RecodeValues":{"8":"-2","9":"-1","10":"0","11":"1","12":"2"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID66","SecondaryAttribute":"${lm:\/\/Field\/1}","TertiaryAttribute":null,"Payload":{"QuestionText":"${lm:\/\/Field\/1}","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID66","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${lm:\/\/Field\/1}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"Hook","TertiaryAttribute":null,"Payload":{"QuestionText":"Hook","DataExportTag":"Hook","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Hook","Choices":{"1":{"Display":"Question"},"2":{"Display":"Cliffhanger"},"3":{"Display":"Anecdote"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID67","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"Length","TertiaryAttribute":null,"Payload":{"QuestionText":"Length","DataExportTag":"Length","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Length","Choices":{"1":{"Display":"Less than 400 characters"},"2":{"Display":"400-1400 characters"},"3":{"Display":"1400-2400 characters"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID68","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"Tone","TertiaryAttribute":null,"Payload":{"QuestionText":"Tone","DataExportTag":"Tone","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Tone","Choices":{"1":{"Display":"First-Person"},"2":{"Display":"Third-Person"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID69","RecodeValues":{"1":"0","2":"1"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID70","SecondaryAttribute":"Content","TertiaryAttribute":null,"Payload":{"QuestionText":"Content","DataExportTag":"Content","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Content","Choices":{"1":{"Display":"Text"},"2":{"Display":"Text + Picture"},"3":{"Display":"Text + Poll"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID70","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID71","SecondaryAttribute":"READ THIS QUESTION CAREFULLY: You may earn a 50GBP bonus! Here are the features of posts expected...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>READ THIS QUESTION CAREFULLY: You may earn a 50GBP bonus!<\/strong><br>\n<br>\nHere are the features of posts expected to generate \"strong\" and \"weak\" engagement that you indicated:<br>\n&nbsp;\n<table style=\"width:500px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>Features<\/td>\n\t\t\t<td>Strong Engagement<\/td>\n\t\t\t<td>Weak Engagement<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Hook<\/td>\n\t\t\t<td>${q:\/\/1_QID67\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID67\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Length<\/td>\n\t\t\t<td>${q:\/\/1_QID68\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID68\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Tone<\/td>\n\t\t\t<td>${q:\/\/1_QID69\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID69\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Content<\/td>\n\t\t\t<td>${q:\/\/1_QID70\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID70\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Call to Action<\/td>\n\t\t\t<td>${q:\/\/1_QID78\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID78\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br>\nNow imagine that you write two posts: One with the \"strong engagement\" features, the other one with the \"weak engagement\" features.&nbsp;<br>\n<br>\nIn your opinion, <strong>how likely it is that the \"strong\" post will receive more likes&nbsp;<\/strong>than the \"week\" post?\n\n<ul>\n\t<li>50% chance means that the \"strong\" post is&nbsp;expected to generate as many likes&nbsp;as the other: The features of posts have very little impact on how many likes they receive.<\/li>\n\t<li>100% chance&nbsp;means that the \"strong\" post is&nbsp;guaranteed to generate more likes than&nbsp;the other: The features of posts have a very strong&nbsp;impact on how many likes they receive.<\/li>\n<\/ul>\n<br>\nOn our side, we will simulate how often a post with these \"strong engagement\" features actually outperforms a post with these \"weak engagement\" features, and compare this result to your answer.<br>\n<br>\nIf your answer is more accurate than the answers of the other participants, you will win a 50GBP bonus on Prolific!","DefaultChoices":false,"DataExportTag":"EdgeProbability","QuestionID":"QID71","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"READ THIS QUESTION CAREFULLY: You may earn a 50GBP bonus! Here are the features of posts expected...","Choices":{"4":{"Display":"50% chance"},"5":{"Display":"55%"},"6":{"Display":"60%"},"12":{"Display":"65%"},"13":{"Display":"70%"},"14":{"Display":"75%"},"15":{"Display":"80%"},"16":{"Display":"85%"},"17":{"Display":"90%"},"18":{"Display":"95%"},"19":{"Display":"100% chance"}},"ChoiceOrder":["4","5","6","12","13","14","15","16","17","18","19"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":3,"RecodeValues":{"4":"50","5":"55","6":"60","12":"65","13":"70","14":"75","15":"80","16":"85","17":"90","18":"95","19":"100"}}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID74","SecondaryAttribute":"Thank you for the playing the game! We now have a few questions for you. In this final portion of...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for the playing the game! We now have a few questions for you. <br><br>In this final portion of the study, there are no right or wrong answers and no attention checks: We are strictly interested in what YOU think.","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID74","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for the playing the game! We now have a few questions for you. In this final portion of...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID76","SecondaryAttribute":"Finally, please tell us about your learning strategy during the game. Out of the eight weeks, in...","TertiaryAttribute":null,"Payload":{"QuestionText":"Finally, please tell us about your learning strategy during the game. <br><br>Out of the eight weeks, in how many weeks did you...","DefaultChoices":false,"DataExportTag":"PTT","QuestionID":"QID76","QuestionType":"CS","Selector":"VRTL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":8},"QuestionDescription":"Finally, please tell us about your learning strategy during the game. Out of the eight weeks, in...","Choices":{"1":{"Display":"... select meeting practices that you predicted would improve performance"},"2":{"Display":"... select meeting practices that you predicted would lower performance"},"4":{"Display":"... select meeting practices at random"}},"ChoiceOrder":["1","2","4"],"Validation":{"Settings":{"EnforceRange":"ON","Type":"ChoicesTotal","ChoiceTotal":"8"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"ClarifyingSymbolType":"None"}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID77","SecondaryAttribute":"Next, please tell us the extent to which you agree or disagree with each of the following stateme...","TertiaryAttribute":null,"Payload":{"QuestionText":"Next, please tell us the extent to which you agree or disagree with each of the following statements.&nbsp;","DefaultChoices":false,"DataExportTag":"DV2","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","Autoscale":{"XScale":{"Name":"agreeDisagree","Type":"likert","Reverse":false}},"ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Next, please tell us the extent to which you agree or disagree with each of the following stateme...","Choices":{"1":{"Display":"I managed to learn which features of posts (if any) had an impact on the engagement they received"},"3":{"Display":"I understood how the features of posts relate to their engagement"},"6":{"Display":"I know which features affected the engagement of posts, and in which direction"}},"ChoiceOrder":["1","3","6"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"RecodeValues":{"8":"-2","9":"-1","10":"0","11":"1","12":"2"},"GradingData":[],"Language":[],"NextChoiceId":8,"NextAnswerId":13,"Answers":{"8":{"Display":"Strongly disagree"},"9":{"Display":"Somewhat disagree"},"10":{"Display":"Neither agree nor disagree"},"11":{"Display":"Somewhat agree"},"12":{"Display":"Strongly agree"}},"AnswerOrder":["8","9","10","11","12"],"ChoiceDataExportTags":{"1":"CouldLearn_1","3":"CouldLearn_2","6":"CouldLearn_3"},"QuestionID":"QID77"}},{"SurveyID":"SV_6u3fCYGZeg551tQ","Element":"SQ","PrimaryAttribute":"QID78","SecondaryAttribute":"Call to Action","TertiaryAttribute":null,"Payload":{"QuestionText":"Call to Action","DataExportTag":"CTA","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Call to Action","Choices":{"1":{"Display":"'Like and Comment'"},"2":{"Display":"No Call to Action"}},"ChoiceOrder":["1"