nLoop":"no","ChoiceLocator":"q:\/\/QID24\/SelectableChoice\/4\/2","Operator":"Selected","QuestionIDFromLocator":"QID24","LeftOperand":"q:\/\/QID24\/SelectableChoice\/4\/2","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...<\/span> <span class=\"LeftOpDesc\">My goal is to learn which (if any) meeting practices affect the performance of the sales team - FALSE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"Or"},"4":{"LogicType":"Question","QuestionID":"QID24","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID24\/SelectableChoice\/5\/1","Operator":"Selected","QuestionIDFromLocator":"QID24","LeftOperand":"q:\/\/QID24\/SelectableChoice\/5\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...<\/span> <span class=\"LeftOpDesc\">The better the sales team performs during the experiment, the happier the CEO will be - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"Or"},"5":{"LogicType":"Question","QuestionID":"QID24","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID24\/SelectableChoice\/6\/2","Operator":"Selected","QuestionIDFromLocator":"QID24","LeftOperand":"q:\/\/QID24\/SelectableChoice\/6\/2","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...<\/span> <span class=\"LeftOpDesc\">The more I learn about the effect of meeting practices on performance, the happier the CEO will be - FALSE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"Or"},"6":{"LogicType":"Question","QuestionID":"QID24","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID24\/SelectableChoice\/7\/1","Operator":"Selected","QuestionIDFromLocator":"QID24","LeftOperand":"q:\/\/QID24\/SelectableChoice\/7\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...<\/span> <span class=\"LeftOpDesc\">If the sales team performs poorly during the experiment, the employees will get in trouble - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"Or"},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"EndSurvey","FlowID":"FL_35","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"DisplayMessage","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSMessage":"MS_bkH5axzDuhgWNYa","ResponseFlag":"Screened"}}]},{"Type":"EndSurvey","FlowID":"FL_36","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"Redirect","EOSRedirectURL":"${e:\/\/Field\/loginURL}","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSMessage":"MS_72IA8iBicxQ5NJz"}}],"Properties":{"Count":39,"RemovedFieldsets":[]}}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"33eb3b5d-696b-4a36-9604-c726278627cd"}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"24","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"RS","PrimaryAttribute":"RS_e4H3K5fviIfum6q","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"Redirect","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SkinLibrary":"cuboulder","SkinType":"templated","Skin":{"brandingId":"2877638256","templateId":"*base","overrides":null},"NewScoring":1,"EOSMessage":"MS_72IA8iBicxQ5NJz","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"Online Survey Software | Qualtrics Survey Solutions","SurveyMetaDescription":"Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.","PasswordProtection":"No","AnonymizeResponse":"No","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","ResponseSummary":"No","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSRedirectURL":"${e:\/\/Field\/loginURL}","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"PartialDeletion":null,"SurveyName":"2024-04-24 - Learning SocialMedia - Pre","CustomStyles":{"customCSS":".project-label {\n  padding: 0 6px 0 6px;\n  color: black;\n}\n\n.project-one {\n  background-color: #ff470f;\n}\n\n.project-two {\n  background-color: #ffdd57;\n}\n\n.project-three {\n  background-color: #23d160;\n}\n\n.project-four {\n  background-color: #00d1b2;\n}"}}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Dear participant, In this study, you are going to play the role of a social media manager in a sm...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dear participant,<br \/>\n<br \/>\nIn this study, you are going to play the role of a social media manager in a small company.<br \/>\n<br \/>\nPlease read the following instructions carefully: <strong>Failure to follow the instructions will prevent you from participating in the study!<\/strong>\n<div>&nbsp;<\/div>\n\n<div>&nbsp;<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dear participant, In this study, you are going to play the role of a social media manager in a sm...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID10","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"In this study, you will play the role a social media manager working in a small company. The CEO...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>In this study, you will play the role a social media manager working in a small company.<br>\n<br>\nThe CEO has assigned an important mission to you: You need to better understand which features of posts (if any) affect the engagement they receive on a social media platform (i.e., how many people \"like\" the post).<br>\n<br>\nSpecifically, the CEO wants you to research how each of the following features relate to the number of likes a post receives:<\/p>\n\n<ul>\n\t<li>\n\t<p><strong>The Hook. <\/strong>Posts can start with a question, a cliffhanger, or an anecdote.&nbsp;<\/p>\n\t<\/li>\n\t<li>\n\t<p><strong>The Length.<\/strong>&nbsp;Posts can be very short (less than 400 characters), average-length (between 400 and 1400 characters), or long (between 1400 and 2400 characters).<\/p>\n\t<\/li>\n\t<li>\n\t<p><strong>The Tone.<\/strong>&nbsp;Posts can be written in a first-person (writing as an employee of the company) or third-person (writing from an outside perspective) tone.&nbsp;&nbsp;<\/p>\n\t<\/li>\n\t<li><b>The Content.&nbsp;<\/b>Posts can include text only, a text and a picture, or a text and a poll.<\/li>\n\t<li>\n\t<p><strong>The Call to Action.&nbsp;<\/strong>Posts can finish with a call-to-action (e.g., \"Like and Comment\") or not.<\/p>\n\t<\/li>\n<\/ul>\n\n<div>&nbsp;<\/div>\n\n<p>To help you conduct this research, the CEO is giving you full freedom to experiment with the posts that will be posted&nbsp; over the next 10 days.&nbsp;<\/p>\n\n<p>Each day,&nbsp;you will define the features of the post that will appear on the social media this day.<br>\n<br>\nAt the end of the day, you will observe the engagement that the post has received (in terms of how many likes it gathered).<\/p>\n\n<p>Here is a screenshot of this task:<br>\n&nbsp;<br>\n&nbsp;&nbsp; <img style=\"width: 600px; height: 253px;\" src=\"https:\/\/cuboulder.qualtrics.com\/CP\/Graphic.php?IM=IM_29LKDC7jtAZIYZ0\"><\/p>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this study, you will play the role a social media manager working in a small company. The CEO...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","TertiaryAttribute":null,"Payload":{"QuestionText":"The game is about to start! Please proceed to the next page when you are ready.<br>\n<br>\nRemember: Your goal is to LEARN whether and how features of social media posts affect the number of likes they receive. If you focus on learning, you may win the 50GBP bonus!","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID20","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how w...","TertiaryAttribute":null,"Payload":{"QuestionText":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how well or poorly the posts perform during the experiment. The only thing that matters to her is that&nbsp;you try to learn which (if any) of these characteristics affect the performance of posts, and in which direction.<br>\n<br>\nIt means you will not be rewarded or penalized for how well the posts perform during the experiment. <br><br>On the other hand, you can be rewarded for how much you learn:&nbsp;<strong>To give you an additional incentive to focus on learning, we will ask you to make a prediction at the end of this task.&nbsp;<\/strong>The participant who gives the most accurate answer will receive a 50GBP bonus on Prolific. If there are multiple correct answers, we will randomly select the winner.","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID21","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how w...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to the instructions that you've read.","DefaultChoices":false,"DataExportTag":"AttChecks","QuestionID":"QID24","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"middle","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","Choices":{"1":{"Display":"I will play the role of a CEO"},"2":{"Display":"I will play the role of a social media manager"},"3":{"Display":"My goal during the experiment is to maximize the number of likes my posts receive"},"4":{"Display":"My goal during the experiment is to learn which features (if any) of posts affect the number of likes they receive"},"5":{"Display":"The CEO cares about how well the posts perform during the experiment"},"6":{"Display":"The CEO cares about how much I learn during the experiment"},"7":{"Display":"If the posts I create during the experiment perform poorly, I will get in trouble"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":10,"NextAnswerId":4,"Answers":{"1":{"Display":"TRUE"},"2":{"Display":"FALSE"}},"AnswerOrder":["1","2"],"ChoiceDataExportTags":{"1":"AttCheck_IsCEO","2":"AttCheck_IsHR","3":"AttCheck_GoalPerform1","4":"AttCheck_GoalLearn1","5":"AttCheck_GoalPerform2","6":"AttCheck_GoalLearn2","7":"AttCheck_InTrouble"},"RecodeValues":{"1":"1","2":"0"}}},{"SurveyID":"SV_ctGnFEahQTzP18W","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":false,"ID":"Survey Statistics"}}]}