play":"Strongly disagree"},"9":{"Display":"Somewhat disagree"},"10":{"Display":"Neither agree nor disagree"},"11":{"Display":"Somewhat agree"},"12":{"Display":"Strongly agree"}},"AnswerOrder":["8","9","10","11","12"],"ChoiceDataExportTags":{"1":"DV_1","3":"DV_2","4":"DV_3","6":"DV_4_R"},"RecodeValues":{"8":"-2","9":"-1","10":"0","11":"1","12":"2"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID66","SecondaryAttribute":"${lm:\/\/Field\/1}","TertiaryAttribute":null,"Payload":{"QuestionText":"${lm:\/\/Field\/1}","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID66","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"${lm:\/\/Field\/1}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID67","SecondaryAttribute":"Duration of Meetings","TertiaryAttribute":null,"Payload":{"QuestionText":"Duration of Meetings","DataExportTag":"Duration","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"Duration of Meetings","Choices":{"1":{"Display":"15 min"},"2":{"Display":"30 min"},"3":{"Display":"45 min"},"4":{"Display":"60 min"}},"ChoiceOrder":["1","2","3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID67","RecodeValues":{"1":"0","2":"1","3":"2","4":"3"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID68","SecondaryAttribute":"Frequency of Meetings","TertiaryAttribute":null,"Payload":{"QuestionText":"Frequency of Meetings","DataExportTag":"Frequency","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Frequency of Meetings","Choices":{"1":{"Display":"Once a week"},"2":{"Display":"Twice a week"},"3":{"Display":"Once a day"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID68","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID69","SecondaryAttribute":"Content of Meetings","TertiaryAttribute":null,"Payload":{"QuestionText":"Content of Meetings","DataExportTag":"Content","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Content of Meetings","Choices":{"1":{"Display":"Unstructured"},"2":{"Display":"Focus on 'Wins'"},"3":{"Display":"Focus on 'Woes'"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID69","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID70","SecondaryAttribute":"Location of Meetings","TertiaryAttribute":null,"Payload":{"QuestionText":"Location of Meetings","DataExportTag":"Location","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Location of Meetings","Choices":{"1":{"Display":"In-Person"},"2":{"Display":"Online"},"3":{"Display":"Hybrid"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionID":"QID70","RecodeValues":{"1":"0","2":"1","3":"2"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID71","SecondaryAttribute":"READ THIS QUESTION CAREFULLY: You may earn a 100GBP bonus! Here are the \"best\" and \"worst\" meetin...","TertiaryAttribute":null,"Payload":{"QuestionText":"<strong>READ THIS QUESTION CAREFULLY: You may earn a 100GBP bonus!<\/strong><br>\n<br>\nHere are the \"best\" and \"worst\" meeting practices that you indicated:<br>\n&nbsp;\n<table style=\"width:500px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<td>Meeting Practice<\/td>\n\t\t\t<td>Best<\/td>\n\t\t\t<td>Worst<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Duration<\/td>\n\t\t\t<td>${q:\/\/1_QID67\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID67\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Frequency<\/td>\n\t\t\t<td>${q:\/\/1_QID68\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID68\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Content<\/td>\n\t\t\t<td>${q:\/\/1_QID69\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID69\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<td>Location<\/td>\n\t\t\t<td>${q:\/\/1_QID70\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t\t<td>${q:\/\/2_QID70\/ChoiceGroup\/SelectedChoices}<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br>\nNow imagine that you select two sales team at random in the company. You randomly assign one to follow these \"best\" meeting practices, and the other to follow these \"worst\" practices. One week later, you check how many leads each team generated.<br>\n<br>\nIn your opinion, <strong>how likely it is that the team following the \"best\" meeting practices will generate more leads<\/strong> than the team following the \"worst\" meeting practices?\n\n<ul>\n\t<li>50% chance means that the team following the \"best\" practices is expected to generate as many leads as the other: Meeting practices have barely any impact on performance.<\/li>\n\t<li>100% chance&nbsp;means that the team following the \"best\" practices is&nbsp;guaranteed to generate more leads than the other: Meeting practices have a very large impact on performance.<\/li><\/ul><br>\nOn our side, we will simulate how often a team following these \"best\" meeting practices actually outperforms a team following these \"worst\" meeting practices, and compare this result to your answer.<br>\n<br>\nIf your answer is more accurate than the answers of the other participants, you will win a 100GBP bonus on Prolific!","DefaultChoices":false,"DataExportTag":"EdgeProbability","QuestionID":"QID71","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"READ THIS QUESTION CAREFULLY: You may earn a 100GBP bonus! Here are the \"best\" and \"worst\" meetin...","Choices":{"4":{"Display":"50% chance"},"5":{"Display":"55%"},"6":{"Display":"60%"},"12":{"Display":"65%"},"13":{"Display":"70%"},"14":{"Display":"75%"},"15":{"Display":"80%"},"16":{"Display":"85%"},"17":{"Display":"90%"},"18":{"Display":"95%"},"19":{"Display":"100% chance"}},"ChoiceOrder":["4","5","6","12","13","14","15","16","17","18","19"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":20,"NextAnswerId":3,"RecodeValues":{"4":"50","5":"55","6":"60","12":"65","13":"70","14":"75","15":"80","16":"85","17":"90","18":"95","19":"100"}}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID74","SecondaryAttribute":"Thank you for the playing the game! We now have a few questions for you. In this final portion of...","TertiaryAttribute":null,"Payload":{"QuestionText":"Thank you for the playing the game! We now have a few questions for you. <br><br>In this final portion of the study, there are no right or wrong answers and no attention checks: We are strictly interested in what YOU think.","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID74","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Thank you for the playing the game! We now have a few questions for you. In this final portion of...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"SQ","PrimaryAttribute":"QID76","SecondaryAttribute":"Finally, please tell us about your learning strategy during the game. Out of the eight weeks, in...","TertiaryAttribute":null,"Payload":{"QuestionText":"Finally, please tell us about your learning strategy during the game. <br><br>Out of the eight weeks, in how many weeks did you...","DefaultChoices":false,"DataExportTag":"PTT","QuestionID":"QID76","QuestionType":"CS","Selector":"VRTL","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":8},"QuestionDescription":"Finally, please tell us about your learning strategy during the game. Out of the eight weeks, in...","Choices":{"1":{"Display":"... select meeting practices that you predicted would improve performance"},"2":{"Display":"... select meeting practices that you predicted would lower performance"},"4":{"Display":"... select meeting practices at random"}},"ChoiceOrder":["1","2","4"],"Validation":{"Settings":{"EnforceRange":"ON","Type":"ChoicesTotal","ChoiceTotal":"8"}},"GradingData":[],"Language":[],"NextChoiceId":5,"NextAnswerId":1,"Labels":[],"ClarifyingSymbolType":"None"}},{"SurveyID":"SV_1BbBVhYtCyzvDV4","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":false,"ID":"Survey Statistics"}}]}