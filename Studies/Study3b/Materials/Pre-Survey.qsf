:"Selected","QuestionIDFromLocator":"QID24","LeftOperand":"q:\/\/QID24\/SelectableChoice\/7\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">Or<\/span> <span class=\"QuestionDesc\">Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...<\/span> <span class=\"LeftOpDesc\">If the sales team performs poorly during the experiment, the employees will get in trouble - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"Or"},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"EndSurvey","FlowID":"FL_35","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"DisplayMessage","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSMessage":"MS_bkH5axzDuhgWNYa","ResponseFlag":"Screened"}}]},{"Type":"EndSurvey","FlowID":"FL_36","EndingType":"Advanced","Options":{"Advanced":"true","SurveyTermination":"Redirect","EOSRedirectURL":"${e:\/\/Field\/loginURL}","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSMessage":"MS_72IA8iBicxQ5NJz"}}],"Properties":{"Count":39,"RemovedFieldsets":[]}}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"ebdf9bf9-76f6-4bcf-acac-8efea45bb8fe"}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"24","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"RS","PrimaryAttribute":"RS_cJbNrIhJSlY6lO6","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"Redirect","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SkinLibrary":"cuboulder","SkinType":"templated","Skin":{"brandingId":"2877638256","templateId":"*base","overrides":null},"NewScoring":1,"EOSMessage":"MS_72IA8iBicxQ5NJz","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"Online Survey Software | Qualtrics Survey Solutions","SurveyMetaDescription":"Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.","PasswordProtection":"No","AnonymizeResponse":"No","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","ResponseSummary":"No","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSRedirectURL":"${e:\/\/Field\/loginURL}","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"PartialDeletion":null,"CustomStyles":{"customCSS":".project-label {\n  padding: 0 6px 0 6px;\n  color: black;\n}\n\n.project-one {\n  background-color: #ff470f;\n}\n\n.project-two {\n  background-color: #ffdd57;\n}\n\n.project-three {\n  background-color: #23d160;\n}\n\n.project-four {\n  background-color: #00d1b2;\n}"}}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Dear participant, In this study, you are going to play the role of a human resources manager in a...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dear participant,\n<br><br>In this study, you are going to play the role of a human resources manager in a large company.<br><br>Please read the following instructions carefully: Failure to follow the instructions will prevent you from participating in the study.<br><div><br><\/div><div><br><\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dear participant, In this study, you are going to play the role of a human resources manager in a...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID10","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"In this study, you will play the role a human resources manager in a large company. The CEO has a...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>In this study, you will play the role a human resources manager in a large company.<br>\n<br>\nThe CEO has assigned an important mission to you: You need to learn which meeting practices (if any) affect the performance of sales teams, and in which direction.<br>\n<br>\nSpecifically, the CEO wants you to research how each of the following meeting practices relate to performance:<\/p>\n\n<ul>\n\t<li>\n\t<p><strong>The Frequency of Meetings. <\/strong>Meeting can happen once a week,&nbsp;twice a week, or once a day.&nbsp;More frequent meetings might improve coordination within the team; less frequent meetings might be less disruptive to the employees' workflow.<\/p>\n\t<\/li>\n\t<li>\n\t<p><strong>The Duration of Meetings.<\/strong>&nbsp;Meetings can range from very short (15 minutes) to very long (one hour). Short meetings might minimize boredom and increase engagement; long meetings might help employees share complex insights.<\/p>\n\t<\/li>\n\t<li>\n\t<p><strong>The Content of Meetings.<\/strong>&nbsp;Meetings can emphasize \"wins\" (i.e., successes, best practices), \"woes\" (i.e., failures, pain points), or be unstructured. Discussing \"wins\" might be more motivating; discussing \"woes\" might be more effective at helping the team improve; unstructured meetings might give employees the freedom to discuss what is most urgent.<\/p>\n\t<\/li>\n\t<li>\n\t<p><strong>The Location of Meetings.<\/strong>&nbsp;Meetings can be in-person only, online only, or in a hybrid setting (mixing online and in-person attendees). In-person meetings might increase sharing and engagement; online meetings might free up time for employees; hybrid meetings might facilitate attendance.<\/p>\n\t<\/li>\n<\/ul>\n\n<p><br>\nTo help you conduct this research, the CEO is giving you full freedom to experiment with the meeting practices of one team of newly hired salespersons.<\/p>\n\n<p>&nbsp;<\/p>\n\n<p>Over the next 8 weeks, you will define, at the beginning of each week, the meeting practices that the team will follow.<br>\n<br>\nAt the end of each week, you will observe the performance that the sales team has achieved (in terms of how many leads they generated).<\/p>\n\n<p>&nbsp;<\/p>\n\n<p>Here is a screenshot of this task:<br>\n&nbsp;<br>\n&nbsp; <img src=\"https:\/\/cuboulder.qualtrics.com\/CP\/Graphic.php?IM=IM_4SDCMv7Lc7YnLBc\" style=\"width: 599px; height: 400px;\"><\/p>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this study, you will play the role a human resources manager in a large company. The CEO has a...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","TertiaryAttribute":null,"Payload":{"QuestionText":"The game is about to start! Please proceed to the next page when you are ready.<br>\n<br>\nRemember: Your goal is to LEARN whether and how meeting modalities affect the performance of the sales team. If you focus on learning, you may win the 100GBP bonus!","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID20","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how w...","TertiaryAttribute":null,"Payload":{"QuestionText":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how well or poorly the sales team performs during the experiment. The only thing that matters to her is that&nbsp;you try to learn which (if any) of the meeting practices affect performance, and in which direction.<br>\n<br>\nIt means&nbsp;that neither you nor the sales team will be rewarded or penalized for how well they perform during the experiment.<br>\n<br>\n<strong>To give you an additional incentive to focus on learning, we will ask you to make a prediction at the end of this task:<\/strong> The participant who gives the most accurate answer will receive a 100GBP bonus on Prolific. If there are multiple correct answers, we will randomly select the winner.","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID21","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Before you start, the CEO of the company has made one thing crystal clear: She doesn't care how w...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to the instructions that you've read.","DefaultChoices":false,"DataExportTag":"AttChecks","QuestionID":"QID24","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"middle","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","Choices":{"1":{"Display":"I will play the role of a CEO"},"2":{"Display":"I will play the role of a Human Resources manager"},"3":{"Display":"My goal during the experiment is to maximize the performance of the sales team"},"4":{"Display":"My goal during the experiment is to learn which (if any) meeting practices affect the performance of the sales team"},"5":{"Display":"The CEO cares about how well the sales team performs during the experiment"},"6":{"Display":"The CEO cares about how much I learn about the effect of meeting practices on performance during the experiment"},"7":{"Display":"If the sales team performs poorly during the experiment, the employees will get in trouble"}},"ChoiceOrder":["1","2","3","4","5","6","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":10,"NextAnswerId":4,"Answers":{"1":{"Display":"TRUE"},"2":{"Display":"FALSE"}},"AnswerOrder":["1","2"],"ChoiceDataExportTags":{"1":"AttCheck_IsCEO","2":"AttCheck_IsHR","3":"AttCheck_GoalPerform1","4":"AttCheck_GoalLearn1","5":"AttCheck_GoalPerform2","6":"AttCheck_GoalLearn2","7":"AttCheck_InTrouble"},"RecodeValues":{"1":"1","2":"0"}}},{"SurveyID":"SV_1N8qDTGFcF4wR82","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}