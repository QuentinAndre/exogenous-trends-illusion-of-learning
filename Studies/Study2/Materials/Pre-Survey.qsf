nIDFromLocator":"QID25","LeftOperand":"q:\/\/QID25\/SelectableChoice\/2\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">To test your understanding of these instructions, please indicate, for each the following stateme...<\/span> <span class=\"LeftOpDesc\">According to the instructions, you will play the role of an investor - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"1":{"LogicType":"Question","QuestionID":"QID25","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID25\/SelectableChoice\/4\/1","Operator":"Selected","QuestionIDFromLocator":"QID25","LeftOperand":"q:\/\/QID25\/SelectableChoice\/4\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">To test your understanding of these instructions, please indicate, for each the following stateme...<\/span> <span class=\"LeftOpDesc\">According to the instructions, your goal is to learn which (if any) characteristics of companies affect their ROIs, and in which direction. - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"And"},"2":{"LogicType":"Question","QuestionID":"QID25","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID25\/SelectableChoice\/6\/2","Operator":"Selected","QuestionIDFromLocator":"QID25","LeftOperand":"q:\/\/QID25\/SelectableChoice\/6\/2","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">To test your understanding of these instructions, please indicate, for each the following stateme...<\/span> <span class=\"LeftOpDesc\">According to the instructions, your goal is to maximize your ROI during the game - FALSE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"And"},"3":{"LogicType":"Question","QuestionID":"QID25","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID25\/SelectableChoice\/13\/2","Operator":"Selected","QuestionIDFromLocator":"QID25","LeftOperand":"q:\/\/QID25\/SelectableChoice\/13\/2","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">To test your understanding of these instructions, please indicate, for each the following stateme...<\/span> <span class=\"LeftOpDesc\">According to the instructions, you will play the role of a marketing manager - FALSE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"And"},"4":{"LogicType":"Question","QuestionID":"QID25","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID25\/SelectableChoice\/14\/1","Operator":"Selected","QuestionIDFromLocator":"QID25","LeftOperand":"q:\/\/QID25\/SelectableChoice\/14\/1","Type":"Expression","Description":"<span class=\"ConjDesc\">And<\/span> <span class=\"QuestionDesc\">To test your understanding of these instructions, please indicate, for each the following stateme...<\/span> <span class=\"LeftOpDesc\">According to the instructions, the ROIs might increase or decrease over the twenty rounds, independently of your actions - TRUE<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","Conjuction":"And"},"Type":"If"},"Type":"BooleanExpression"},"Flow":[{"Type":"EndSurvey","FlowID":"FL_38"}]},{"Type":"EndSurvey","FlowID":"FL_39","EndingType":"Advanced","Options":{"Advanced":"true","ResponseFlag":"Screened","SurveyTermination":"DisplayMessage","EOSRedirectURL":"https:\/\/app.prolific.com\/submissions\/complete?cc=CQ9FB1LF","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSMessage":"MS_bkH5axzDuhgWNYa"}}],"Properties":{"Count":41}}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"PL","PrimaryAttribute":"Preview Link","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"PreviewType":"Brand","PreviewID":"0318ff65-1e4d-487f-90f7-493baac3cf1d"}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"PROJ","PrimaryAttribute":"CORE","SecondaryAttribute":null,"TertiaryAttribute":"1.1.0","Payload":{"ProjectCategory":"CORE","SchemaVersion":"1.1.0"}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"QC","PrimaryAttribute":"Survey Question Count","SecondaryAttribute":"25","TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"RS","PrimaryAttribute":"RS_8APDWIRz9x3XEVw","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":null},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"DisplayMessage","Header":"<script>\n\/\/ Helper functions for formatting numbers\nfunction asDollarAmount(x) {\n    return \"$\" + x.toLocaleString(\"en-US\", { minimumFractionDigits: 0, maximumFractionDigits: 0 });\n}\n\nfunction asAmount(x) {\n    return x.toLocaleString(\"en-US\", { minimumFractionDigits: 0, maximumFractionDigits: 0 });\n}\n\n\/\/ Main function to generate signal range\nfunction generateSignalRange(x, tokens, attribute) {\n    let exclusionLevel = tokens * 10;\n\n    \/\/ Ensure exclusionLevel is between 0 and 100\n    if (exclusionLevel < 0 || exclusionLevel > 100) {\n        throw new Error(\"Exclusion level must be between 0 and 100.\");\n    }\n\n    let A, B;\n\n    if (attribute === \"valuation\") {\n        A = 50000;\n        B = 3000000;\n    } else if (attribute === \"competitors\") {\n        A = 2;\n        B = 14;\n    } else if (attribute === \"customers\") {\n        A = 2000;\n        B = 14000;\n    } else {\n        const possibleValues = [\"Robotics\", \"Electronics\", \"Biotechnology\"];\n        if (exclusionLevel < 40) {\n            return \"Robotics, Electronics, or Biotechnology\";\n        } else if (exclusionLevel < 70) {\n            const sampledValue = possibleValues.filter(value => value !== x)[Math.floor(Math.random() * 2)];\n            return `${x} or ${sampledValue}`;\n        } else {\n            return x;\n        }\n    }\n\n    \/\/ Calculate the inclusion fraction and inclusion width\n    const inclusionFraction = (100 - exclusionLevel) \/ 100;\n    const totalRange = B - A;\n    const inclusionWidth = totalRange * inclusionFraction;\n\n    \/\/ Define the bounds of the inclusion range\n    let lowerBound = Math.max(A, x - inclusionWidth \/ 2);\n    let upperBound = Math.min(B, x + inclusionWidth \/ 2);\n\n    \/\/ Adjust bounds to ensure the range aligns with inclusion width\n    if ((upperBound - lowerBound) < inclusionWidth) {\n        if (lowerBound === A) {\n            upperBound = A + inclusionWidth;\n        } else if (upperBound === B) {\n            lowerBound = B - inclusionWidth;\n        }\n    }\n\n    \/\/ Format and return the range\n    if (lowerBound !== upperBound) {\n        const values = [Math.round(lowerBound), Math.round(upperBound)];\n        if (attribute === \"valuation\") {\n            return values.map(asDollarAmount).join(\"-\");\n        } else {\n            return values.map(asAmount).join(\"-\");\n        }\n    } else {\n        const value = Math.round(lowerBound);\n        if (attribute === \"valuation\") {\n            return asDollarAmount(value);\n        } else {\n            return asAmount(value);\n        }\n    }\n}\n<\/script>","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SkinLibrary":"cuboulder","SkinType":"templated","Skin":{"brandingId":"2877638256","templateId":"*base","overrides":null},"NewScoring":1,"EOSMessage":"MS_72IA8iBicxQ5NJz","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"Online Survey Software | Qualtrics Survey Solutions","SurveyMetaDescription":"Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.","PasswordProtection":"No","AnonymizeResponse":"No","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","ResponseSummary":"No","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSRedirectURL":"https:\/\/","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":"","SurveyLinkCompletedMessageLibrary":"","headerMid":"","BallotBoxStuffingPreventionBehavior":null,"BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"false","ConfirmStart":false,"AutoConfirmStart":false,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","PartialDeletion":null,"SurveyName":"2025-09-05 - Investing Slope Warning - Pre","ProtectSelectionIds":true,"CustomStyles":{"customCSS":".project-label {\n  padding: 0 6px 0 6px;\n  color: black;\n}\n\n.project-one {\n  background-color: #ff470f;\n}\n\n.project-two {\n  background-color: #ffdd57;\n}\n\n.project-three {\n  background-color: #23d160;\n}\n\n.project-four {\n  background-color: #00d1b2;\n}"}}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"In this game, you will play the role of a researcher\u00a0attempting to learn the factors that predict..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>In this game, you will play the role of a researcher&nbsp;<strong>attempting to learn the factors that predict the success or failure of companies.<\/strong><\/div>\n\n<div>&nbsp;<\/div>\n\n<div>Each round, you will see three different investment prospects, each defined by their four characteristics:<\/div>\n<br>\n<img src=\"https:\/\/cuboulder.qualtrics.com\/CP\/Graphic.php?IM=IM_bCTHvDq2hDW8uOy\" style=\"width: 600px; height: 155px;\">\n<ul>\n\t<li><strong>Company Valuation:<\/strong> The current value of the company, in dollars (between $500,000 and $3,000,000).<\/li>\n\t<li><strong>Sector of Activity:&nbsp;<\/strong>The core business of the company (Electronics, Robotics, or Biotechnology).<\/li>\n\t<li><strong>Market Size:&nbsp;<\/strong>The number of customers who could be interested in the product that the company is selling (between 2000 and 14,000).<\/li>\n\t<li><strong>Number of Competitors:&nbsp;<\/strong>The number of competitors that the company currently has (between 2 and 14).<\/li>\n<\/ul>\n<br>\nYou will choose, each round, one company in which to invest.<br>\n&nbsp;","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this game, you will play the role of a researcher\u00a0attempting to learn the factors that predict...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"After playing 20 rounds, the game will end, and a survey will begin. \u00a0 You will receive your vali..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div><strong>After playing 20 rounds, the game will end, and a survey will begin.<\/strong><\/div>\n\n<div>&nbsp;<\/div>\n\n<div><\/div>\n\n<div>You will receive your validation link at the end of this second survey.<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"After playing 20 rounds, the game will end, and a survey will begin. \u00a0 You will receive your vali...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID20"}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SQ","PrimaryAttribute":"QID23","SecondaryAttribute":"Dear participant, \u00a0 Please read the following instructions carefully. You will be tested on your...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dear participant,<br><div>&nbsp;<\/div>\n\n<div>Please read the following instructions carefully.<\/div><div><br><\/div><div>You will be tested on your understanding of these instructions.<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dear participant, \u00a0 Please read the following instructions carefully. You will be tested on your...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID23"}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"After you made your decision, we will reveal the Return On Investment (ROI) that you earned from...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div>After you made your decision, we will reveal the Return On Investment (ROI) that you earned from this investment.<\/div>\n\n<div>\n<div>&nbsp;<\/div>\n\n<div><span style=\"color:#c0392b;\">Note that, as a researcher, <strong>your goal is NOT to earn the highest possible ROIs. <\/strong><\/span><\/div>\n\n<div><em>&nbsp;<\/em><\/div>\n<\/div>\n\n<div><span style=\"color:#27ae60;\"><em><strong>Your ONLY goal for this study is to learn which characteristic(s), if any, affect the ROIs that you get, and in which direction.&nbsp;<\/strong><\/em><\/span><\/div>\n\n<div>&nbsp;<\/div>\n\n<div>\n<div><em><strong>Learning the relationship(s) between the characteristics and the ROIs might not be easy, for two reasons:<\/strong><\/em><\/div>\n\n<ul>\n\t<li>The companies have many characteristics, and <strong>it is unclear which of them,&nbsp;if any, affect the ROI that you get.<\/strong><\/li>\n\t<li>Because of market-level changes, the ROIs of your investments&nbsp;<strong>may tend to increase over the twenty rounds, independently of which companies you invest in<\/strong><\/li>\n<\/ul>\n<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID24","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"After you made your decision, we will reveal the Return On Investment (ROI) that you earned from...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"SQ","PrimaryAttribute":"QID25","SecondaryAttribute":"To test your understanding of these instructions, please indicate, for each the following stateme...","TertiaryAttribute":null,"Payload":{"AnswerOrder":["1","2"],"Answers":{"1":{"Display":"TRUE"},"2":{"Display":"FALSE"}},"ChoiceDataExportTags":{"2":"AttCheck_IsHR","4":"AttCheck_GoalLearn1","6":"AttCheck_GoalLearn2","13":"AttChecks_13","14":"AttChecks_14"},"ChoiceOrder":["2","13","4","6","14"],"Choices":{"2":{"Display":"According to the instructions, you will play the role of a researcher"},"4":{"Display":"According to the instructions, your goal is to learn which (if any) characteristics of companies affect their ROIs, and in which direction."},"6":{"Display":"According to the instructions, your goal is to maximize your ROIs during the game"},"13":{"Display":"According to the instructions, you will play the role of a marketing manager"},"14":{"Display":"According to the instructions, the ROIs may tend to increase over the twenty rounds, regardless of which companies you invest in"}},"Configuration":{"ChoiceColumnWidth":25,"MobileFirst":true,"QuestionDescriptionOption":"UseText","RepeatHeaders":"middle","TextPosition":"inline","WhiteSpace":"OFF","ChoiceColumnWidthPixels":340},"DataExportTag":"AttChecks","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":4,"NextChoiceId":15,"QuestionDescription":"To test your understanding of these instructions, please indicate, for each the following stateme...","QuestionID":"QID25","QuestionText":"To test your understanding of these instructions, please indicate, for each the following statements, whether they are TRUE or FALSE.<br>\n<br>\n<strong>Please answer carefully:<\/strong> If you make a mistake, you will not be able to participate, and you will have to return the task.","QuestionText_Unsafe":"To test your understanding of these instructions, please indicate, for each the following statements, whether they are TRUE or FALSE.","QuestionType":"Matrix","RecodeValues":{"1":"1","2":"0"},"Selector":"Likert","SubSelector":"SingleAnswer","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_bOh1i3GjQRZwnae","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}