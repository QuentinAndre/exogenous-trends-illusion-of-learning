":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Now, we are going to show you a list of statements about the relationships between company charac...","Choices":{"1":{"Display":"... a larger Number of Competitors had a NEGATIVE impact on the ROI"},"2":{"Display":"... a larger Market Size had a POSITIVE impact on the ROI"},"3":{"Display":"... a larger Company Valuation had a POSITIVE impact on the ROI"}},"ChoiceOrder":[1,2,3],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":6,"Answers":{"1":{"Display":"Not at all confident (1)"},"2":{"Display":"2"},"3":{"Display":"3"},"4":{"Display":"4"},"5":{"Display":"Extremely confident (5)"}},"AnswerOrder":["1","2","3","4","5"],"ChoiceDataExportTags":{"1":"Confidence_NC","2":"Confidence_MS","3":"Confidence_CV"},"Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"}}},{"SurveyID":"SV_e4hNiBKgCaqNcx0","Element":"SQ","PrimaryAttribute":"QID80","SecondaryAttribute":"Finally, what do you think was true during the game you played?","TertiaryAttribute":null,"Payload":{"QuestionText":"Finally, what do you think was true during the game you played?","DataExportTag":"Slope","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Finally, what do you think was true during the game you played?","Choices":{"1":{"Display":"The ROI tended to increase over time, independently of which company I decided to invest in"},"2":{"Display":"The ROI tended to stay constant over time, independently of which company I decided to invest in"}},"ChoiceOrder":[1,2],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionID":"QID80"}},{"SurveyID":"SV_e4hNiBKgCaqNcx0","Element":"STAT","PrimaryAttribute":"Survey Statistics","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"MobileCompatible":true,"ID":"Survey Statistics"}}]}