ll,"Payload":null},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SCO","PrimaryAttribute":"Scoring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"true","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"Redirect","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+1 week","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SkinLibrary":"cuboulder","SkinType":"templated","Skin":{"brandingId":"2877638256","templateId":"*base","overrides":null},"NewScoring":1,"EOSMessage":"MS_72IA8iBicxQ5NJz","ShowExportTags":"false","CollectGeoLocation":"false","SurveyTitle":"Online Survey Software | Qualtrics Survey Solutions","SurveyMetaDescription":"Qualtrics sophisticated online survey software solutions make creating online surveys easy. Learn more about Research Suite and get a free account today.","PasswordProtection":"No","AnonymizeResponse":"No","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","ResponseSummary":"No","EOSMessageLibrary":"UR_8HNsUBv4Xq1C36B","EOSRedirectURL":"${e:\/\/Field\/loginURL}","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]},"ProtectSelectionIds":true,"BallotBoxStuffingPreventionBehavior":"DefaultMessage","BallotBoxStuffingPreventionMessage":null,"BallotBoxStuffingPreventionMessageLibrary":null,"BallotBoxStuffingPreventionURL":null,"RecaptchaV3":"true","ConfirmStart":true,"AutoConfirmStart":true,"RelevantID":"false","RelevantIDLockoutPeriod":"+30 days","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessageLibrary":null,"PartialDeletion":null,"SurveyName":"2024-05-08 - Learning Items - Pre","CustomStyles":{"customCSS":".project-label {\n  padding: 0 6px 0 6px;\n  color: black;\n}\n\n.project-one {\n  background-color: #ff470f;\n}\n\n.project-two {\n  background-color: #ffdd57;\n}\n\n.project-three {\n  background-color: #23d160;\n}\n\n.project-four {\n  background-color: #00d1b2;\n}"}}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SQ","PrimaryAttribute":"QID10","SecondaryAttribute":"Dear participant, In this study, you will try to understand how the decisions you make relate to...","TertiaryAttribute":null,"Payload":{"QuestionText":"Dear participant,<br>\n<br>\nIn this study, you will try to understand how the decisions you make relate to an outcome you observe.<br>\n<br>\nPlease read the following instructions carefully: <strong>Failure to follow the instructions will prevent you from participating in the study!<\/strong>\n<div>&nbsp;<\/div>\n\n<div>&nbsp;<\/div>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Dear participant, In this study, you will try to understand how the decisions you make relate to...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID10","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SQ","PrimaryAttribute":"QID12","SecondaryAttribute":"In this study, you will make repeated decisions, and try to learn how the decisions you make rela...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p>In this study, you will make repeated decisions, and try to learn how the decisions you make relate to the outcomes that you observe.<br>\n<br>\nTo make sure that your prior beliefs about the world do not affect your ability to learn, this task involves abstract decisions: You will create \"items\", and see how many \"points\" they receive.<\/p>\n\n<p><br>\nSpecifically, you will be asked to create 8 items, by varying the following characteristics:<\/p>\n\n<ul>\n\t<li><b>The Shape: <\/b>The item can be a circle, a square, or a triangle.<\/li>\n\t<li><b>The Color: <\/b>The item can be black, grey, or white.<\/li>\n\t<li><strong>The Size:<\/strong> The item can be small, medium, or large.<\/li>\n\t<li><strong>The Texture:<\/strong> The item can be smooth or rugged.<\/li>\n<\/ul>\n\n<p>After creating each item, you will see how many \"points\" the item received.<br>\n<br>\nHere is a screenshot of the task:<br>\n&nbsp;<\/p>\n\n<p><img style=\"width: 499px; height: 249px;\" src=\"https:\/\/cuboulder.qualtrics.com\/CP\/Graphic.php?IM=IM_08IGEXH8MkSn2dg\"><br>\n<br>\nAfter creating eight items and observing their outcomes, the game will end, and you will be redirected to a survey.<\/p>","DefaultChoices":false,"DataExportTag":"T","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"In this study, you will make repeated decisions, and try to learn how the decisions you make rela...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID12"}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","TertiaryAttribute":null,"Payload":{"QuestionText":"The game is about to start! Please proceed to the next page when you are ready.<br>\n<br>\nRemember: Your goal is to LEARN whether and how characteristics of items affect the number of points they receive. If you focus on learning, you may win the 50GBP bonus!","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID20","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"The game is about to start! Please proceed to the next page when you are ready. Remember: Your go...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SQ","PrimaryAttribute":"QID21","SecondaryAttribute":"Before you start, we want to make one thing extremely clear: It doesn't matter how many \"points\"...","TertiaryAttribute":null,"Payload":{"QuestionText":"Before you start, we want to make one thing extremely clear: <strong>It doesn&#39;t matter how many &quot;points&quot; your items receive, and y<\/strong><strong>ou will not be rewarded or penalized for how many points you get.<\/strong><br \/>\n<br \/>\n<strong>Your only goal is to&nbsp;try to learn which (if any) of the item characteristics affect the number of points they receive, and if so in which direction.<\/strong><br \/>\n<br \/>\nOn the other hand, you can be rewarded for how much you learn:&nbsp;<strong>To give you an additional incentive to focus on learning, we will ask you to make a prediction at the end of this study.&nbsp;<\/strong>The participant who gives the most accurate answer will receive a 50GBP bonus on Prolific. If there are multiple correct answers, we will randomly select the winner.","DefaultChoices":false,"DataExportTag":"T","QuestionID":"QID21","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Before you start, we want to make one thing extremely clear: It doesn't matter how many \"points\"...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to the instructions that you've read.","DefaultChoices":false,"DataExportTag":"AttChecks","QuestionID":"QID24","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"middle","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"Please indicate, for each the following statements, whether they are TRUE or FALSE according to t...","Choices":{"3":{"Display":"My goal during the experiment is to maximize the number of points my items receive"},"4":{"Display":"My goal during the experiment is to learn which characteristics (if any) affect the number of points items receive"},"7":{"Display":"If the items I create get enough points, I might earn a bonus"},"10":{"Display":"If I manage to learn which characteristics (if any) predict the number of points an item receives, I might earn a bonus."}},"ChoiceOrder":["3","4","7","10"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":4,"Answers":{"1":{"Display":"TRUE"},"2":{"Display":"FALSE"}},"AnswerOrder":["1","2"],"ChoiceDataExportTags":{"3":"AttCheck_GoalPerform","4":"AttCheck_GoalLearn","7":"AttCheck_BonusPerform","10":"AttCheck_BonusLearn"},"RecodeValues":{"1":"1","2":"0"}}},{"SurveyID":"SV_bkE3CFRSjQukGCa","Element":"STAT","PrimaryAttribute":"Survey 